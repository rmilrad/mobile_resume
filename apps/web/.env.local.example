# ── Demo mode (default) ───────────────────────────────────────────────────────
# No env vars needed. The app runs entirely with the localStorage demo wallet
# and the simulated backend (pnpm dev:backend). Zero chain dependencies.

# ── Onchain mode (Base Sepolia testnet) ───────────────────────────────────────
# Set NEXT_PUBLIC_FACTORY_ADDRESS to switch from demo wallet to real contracts.
# Deploy first: cd packages/contracts && forge script script/Deploy.s.sol --rpc-url base_sepolia --broadcast

# Deployed contract addresses (from Deploy.s.sol output)
NEXT_PUBLIC_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_USDC_ADDRESS=0x...

# Base Sepolia RPC — free public endpoint works; use a private one for production
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Coinbase Developer Platform — get a free key at https://portal.cdp.coinbase.com/
# Used by OnchainKit if integrated; also required for Smart Wallet on mainnet
# NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# Base Paymaster (sponsored gas) — from https://portal.cdp.coinbase.com/ → Paymaster
# Optional: if omitted, users pay their own gas (Base fees are sub-cent anyway on testnet)
# NEXT_PUBLIC_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base-sepolia/...
